<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<groupId>com.cognizant.cloudset</groupId>
	<artifactId>pre-flight-parent</artifactId>
	<version>1.0.0-SNAPSHOT</version>
	<packaging>pom</packaging>
	<name>pre-flight-parent</name>

	<modules>
		<module>pre-flight-core</module>
		<module>pre-flight-test</module>
		<module>pre-flight-maven-plugin</module>
	</modules>

	<properties>
		<parent.version>1.0.0-SNAPSHOT</parent.version>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<project.java.source>1.6</project.java.source>
		<project.java.target>1.6</project.java.target>
		<junit.version>4.11</junit.version>
		<jenkins-cli.version>1.0.0</jenkins-cli.version>
		<commons-io.version>2.2</commons-io.version>
		<commons-lang.version>2.6</commons-lang.version>
		<commons-collection.version>3.2</commons-collection.version>
		<eclipse-jgit.version>3.2.0.201312181205-r</eclipse-jgit.version>
		<property-binder.version>3.1</property-binder.version>
		<maven-compiler-plugin.version>2.3.2</maven-compiler-plugin.version>
		<maven-assembly-plugin.version>2.4</maven-assembly-plugin.version>
		<findbugs-maven-plugin.version>2.5.2</findbugs-maven-plugin.version>
		<mavenVersion>2.2.1</mavenVersion>
		<mavenPluginVersion>3.2</mavenPluginVersion>
	</properties>

	<dependencies>
		<dependency>
			<groupId>org.apache.maven</groupId>
			<artifactId>maven-plugin-api</artifactId>
			<version>${mavenVersion}</version>
		</dependency>
		<dependency>
			<groupId>org.apache.maven.plugin-tools</groupId>
			<artifactId>maven-plugin-annotations</artifactId>
			<version>${mavenPluginVersion}</version>			
		</dependency>
		<dependency>
			<groupId>junit</groupId>
			<artifactId>junit</artifactId>
			<version>${junit.version}</version>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>jenkins</groupId>
			<artifactId>cli-jar</artifactId>
			<version>${jenkins-cli.version}</version>			
		</dependency>
		<dependency>
			<groupId>commons-io</groupId>
			<artifactId>commons-io</artifactId>
			<version>${commons-io.version}</version>
			<type>jar</type>
		</dependency>
		<dependency>
			<groupId>commons-lang</groupId>
			<artifactId>commons-lang</artifactId>
			<version>${commons-lang.version}</version>
			<type>jar</type>
		</dependency>
		<dependency>
			<groupId>commons-collections</groupId>
			<artifactId>commons-collections</artifactId>
			<version>${commons-collection.version}</version>
		</dependency>
		<dependency>
			<groupId>org.eclipse.jgit</groupId>
			<artifactId>org.eclipse.jgit</artifactId>
			<version>${eclipse-jgit.version}</version>
		</dependency>
		<dependency>
			<groupId>com.pholser</groupId>
			<artifactId>property-binder</artifactId>
			<version>${property-binder.version}</version>
		</dependency>
		<dependency>
			<groupId>com.google.code.findbugs</groupId>
			<artifactId>annotations</artifactId>
			<version>2.0.1</version>
		</dependency>
	</dependencies>
	<build>
		<plugins>
			<plugin>
				<artifactId>maven-compiler-plugin</artifactId>
				<version>${maven-compiler-plugin.version}</version>
				<configuration>
					<source>${project.java.source}</source>
					<target>${project.java.target}</target>
				</configuration>
			</plugin>
			<plugin>
				<artifactId>maven-assembly-plugin</artifactId>
				<version>${maven-assembly-plugin.version}</version>
				<configuration>
					<archive>
						<manifest>
							<mainClass>com.cognizant.cloudset.framework.API</mainClass>
						</manifest>
					</archive>
					<descriptorRefs>
						<descriptorRef>jar-with-dependencies</descriptorRef>
					</descriptorRefs>
				</configuration>
			</plugin>
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>findbugs-maven-plugin</artifactId>
				<version>${findbugs-maven-plugin.version}</version>
				<dependencies>
					<dependency>
						<groupId>com.google.code.findbugs</groupId>
						<artifactId>annotations</artifactId>
						<version>2.0.1</version>
					</dependency>
				</dependencies>
				<configuration>
					<!-- Enables analysis which takes more memory but finds more bugs. If 
						you run out of memory, changes the value of the effort element to 'Low'. -->
					<effort>Max</effort>
					<!-- Reports all bugs (other values are medium and max) -->
					<threshold>Low</threshold>
					<!-- Produces XML report -->
					<xmlOutput>true</xmlOutput>
					<!-- Configures the directory in which the XML report is created -->
					<findbugsXmlOutputDirectory>${project.build.directory}/findbugs</findbugsXmlOutputDirectory>
				</configuration>
				<executions>
					<!-- Ensures that FindBugs inspects source code when project is installed -->
					<execution>
						<id>analyze-compile</id>
						<phase>install</phase>
						<goals>
							<goal>check</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>
	<profiles>
        <profile>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
            <id>jpaas-build-profile-snapshot</id>
            <properties>
                <project.build.groupId>com.cognizant.cloudset</project.build.groupId>
                <project.build.artifactId>pre-flight-parent</project.build.artifactId>
                <project.build.version>${baas.plugin.version}</project.build.version>
            </properties>
            <distributionManagement>
                <repository>
                    <id>${deployment.id}</id>
                    <url>${deployment.url}</url>
                </repository>
            </distributionManagement>
        </profile>
    </profiles>

</project>
