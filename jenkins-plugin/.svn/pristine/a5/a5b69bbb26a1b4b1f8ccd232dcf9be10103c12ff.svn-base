package hudson.plugins.projectstats.resource;

import com.pholser.util.properties.BoundProperty;

public interface PluginProperties {
	

	@BoundProperty("db.url")
    String dbUrl();
	
	@BoundProperty("db.driver.class")
    String dbDriverClass();
	
	@BoundProperty("db.uid")
    String dbUid();
	
	@BoundProperty("db.pwd")
    String dbPwd();
	
	@BoundProperty("db.schema")
    String dbSchema();

	@BoundProperty("db.table")
    String dbTable();

	@BoundProperty("datafederation.url")
	String datafederationUrl();
	
	@BoundProperty("datafederation.truststore.key")
	String datafederationTrustStoreKey();
	
	@BoundProperty("datafederation.truststore.password")
	String datafederationTrustStorePassword();
	
	@BoundProperty("data.interval.time")
	String dataIntervalTime();
}
