package hudson.plugins.cloudset.rbac.util;

public enum Roles {

	Admin("Admin"),
	Release_Manager("Release Manager"),
	build_operator("Build Operator"),
	developer("Developer"),
	Pre_Flight_Builder("Pre Flight Builder"),
	Pre_Flight_Release_Manager("Pre Flight Release Manager");
	
		
	private String desc;
	
	private Roles(String desc){
		this.desc = desc;
	}

	public String getDesc() {
		return desc;
	}

	public void setDesc(String desc) {
		this.desc = desc;
	}	
		
}
