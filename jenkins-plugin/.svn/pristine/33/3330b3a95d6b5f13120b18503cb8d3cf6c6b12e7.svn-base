package com.cognizant.cloudset.framework.command;

import com.cognizant.cloudset.framework.exception.PreflightCoreException;

/**
 * handler interface which needs to be implemented by concrete handlers with appropriate return type
 */
public interface CommandHandler<ParamType> {

	public void execute(ParamType params) throws PreflightCoreException;
}
