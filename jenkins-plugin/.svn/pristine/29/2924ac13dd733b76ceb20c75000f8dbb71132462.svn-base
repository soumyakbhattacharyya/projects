package hudson.plugins.cloud.resource;

import com.pholser.util.properties.BoundProperty;

public interface PluginProperties {

		
	@BoundProperty("vmware_url")
	String vmwareUrl();
	
	@BoundProperty("vmware.infra.sslkeypath")
	String vmwareInfraSslkeypath();
	
	@BoundProperty("vmware.infra.sslpassword")
	String vmwareInfraSslpassword();
	
	@BoundProperty("vmware.infra.addressing")
	String vmwareInfraAddressing();
	
	@BoundProperty("vmware.infra.machineimage")
	String vmwareInfraMachineimage();
	
	@BoundProperty("vmware.infra.virtualmachine")
	String vmwareInfraVirtualmachine();
	
	@BoundProperty("vmware.infra.virtualmachine.ip.discovery.time")
	String vmwareInfraVirtualmachineIpDiscoveryTime();
}
